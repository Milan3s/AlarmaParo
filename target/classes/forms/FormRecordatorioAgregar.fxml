<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="mainFxmlClass" stylesheets="@../styles/formrecordatorioagregar.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.FormRecordatorioAgregarController">

    <children>

        <!-- Título -->
        <Label layoutX="30.0" layoutY="25.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Agregar Recordatorio" />

        <!-- Descripción -->
        <Label layoutX="30.0" layoutY="65.0" style="-fx-font-size: 14px;" text="Configura un nuevo aviso para una renovación existente." />

        <!-- Renovación -->
        <Label layoutX="30.0" layoutY="110.0" text="Renovación" />

        <ComboBox fx:id="cmbRenovacion" layoutX="30.0" layoutY="135.0" prefHeight="40.0" prefWidth="540.0" promptText="Seleccione una renovación..." />

        <!-- Días Antes -->
        <Label layoutX="30.0" layoutY="195.0" text="Días Antes" />

        <Spinner fx:id="spDiasAntes" editable="true" layoutX="30.0" layoutY="220.0" prefHeight="40.0" prefWidth="180.0" />

        <!-- Observaciones -->
        <Label layoutX="250.0" layoutY="195.0" text="Observaciones" />

        <TextArea fx:id="txtObservaciones" layoutX="250.0" layoutY="220.0" prefHeight="40.0" prefWidth="320.0" promptText="Observaciones opcionales..." wrapText="true" />

        <!-- Botones -->
        <Button fx:id="btnGuardar" layoutX="180.0" layoutY="320.0" mnemonicParsing="false" onAction="#guardar" prefHeight="40.0" prefWidth="120.0" text="Guardar" />

        <Button fx:id="btnCancelar" layoutX="310.0" layoutY="320.0" mnemonicParsing="false" onAction="#cancelar" prefHeight="40.0" prefWidth="120.0" text="Cancelar" />

    </children>

</AnchorPane>