<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="mainFxmlClass" stylesheets="@../styles/formborrarrecordatorio.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.FormBorrarRecordatorioController">

    <children>

        <!-- Título -->
        <Label layoutX="30.0" layoutY="25.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Borrar Recordatorio" />

        <!-- Descripción -->
        <Label layoutX="30.0" layoutY="65.0" style="-fx-font-size: 14px;" text="Elimina el recordatorio seleccionado." />

        <!-- Renovación -->
        <Label layoutX="30.0" layoutY="110.0" text="Renovación" />

        <ComboBox fx:id="cmbRenovacion" layoutX="30.0" layoutY="135.0" prefHeight="40.0" prefWidth="540.0" promptText="Renovación..." />

        <!-- Días Antes -->
        <Label layoutX="30.0" layoutY="195.0" text="Días Antes" />

        <Spinner fx:id="spDiasAntes" editable="true" layoutX="30.0" layoutY="220.0" prefHeight="40.0" prefWidth="180.0" />

        <!-- Enviado -->
        <Label layoutX="250.0" layoutY="195.0" text="Enviado" />

        <Label fx:id="lblEnviado" layoutX="250.0" layoutY="220.0" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="No" />

        <!-- Botones -->
        <Button fx:id="btnBorrar" layoutX="200.0" layoutY="320.0" mnemonicParsing="false" onAction="#borrar" prefHeight="40.0" prefWidth="120.0" text="Borrar" />

        <Button fx:id="btnCancelar" layoutX="380.0" layoutY="320.0" mnemonicParsing="false" onAction="#cancelar" prefHeight="40.0" prefWidth="120.0" text="Cancelar" />

    </children>

</AnchorPane>