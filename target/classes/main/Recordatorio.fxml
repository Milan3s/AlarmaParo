<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="888.0" prefWidth="1101.0" styleClass="mainFxmlClass" stylesheets="@../styles/recordatorio.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.RecordatorioController">

    <children>

        <!-- Título -->
        <Label layoutX="30.0" layoutY="25.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Gestión de Recordatorios" />

        <!-- Descripción -->
        <Label layoutX="30.0" layoutY="65.0" style="-fx-font-size: 14px;" text="Consulta, busca y administra los recordatorios registrados." />

        <!-- Buscador -->
        <TextField fx:id="txtBuscar" layoutX="30.0" layoutY="110.0" prefHeight="40.0" prefWidth="370.0" promptText="Buscar por renovación o estado..." />

        <!-- Botón Ver Ficha -->
        <Button fx:id="btnVerFicha" layoutX="415.0" layoutY="110.0" mnemonicParsing="false" onAction="#verFicha" prefHeight="40.0" prefWidth="170.0" text="Ver Ficha" />

        <!-- Botones de acción -->
        <Button fx:id="btnMarcarEnviado" layoutX="30.0" layoutY="172.0" mnemonicParsing="false" onAction="#marcarEnviado" prefHeight="40.0" prefWidth="170.0" text="Marcar Enviado" />

        <Button fx:id="btnDesmarcar" layoutX="227.0" layoutY="172.0" mnemonicParsing="false" onAction="#desmarcarEnviado" prefHeight="40.0" prefWidth="170.0" text="Desmarcar" />

        <Button fx:id="btnEliminar" layoutX="415.0" layoutY="172.0" mnemonicParsing="false" onAction="#eliminarRecordatorio" prefHeight="40.0" prefWidth="170.0" text="Borrar Recordatorio" />

        <!-- Tabla -->
        <TableView fx:id="tblRecordatorios" layoutX="30.0" layoutY="230.0" prefHeight="630.0" prefWidth="1004.0">

            <columns>

                <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />

                <TableColumn fx:id="colRenovacion" prefWidth="276.0" text="Renovación" />

                <TableColumn fx:id="colDiasAntes" prefWidth="218.0" text="Días Antes" />

                <TableColumn fx:id="colEnviado" prefWidth="210.0" text="Enviado" />

                <TableColumn fx:id="colFechaEnvio" prefWidth="226.0" text="Fecha Envío" />

            </columns>

        </TableView>

    </children>

</AnchorPane>