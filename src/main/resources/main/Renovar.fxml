<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="888.0" prefWidth="1101.0" styleClass="mainFxmlClass" stylesheets="@../styles/renovar.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.RenovarController">

    <children>

        <!-- Título -->
        <Label layoutX="30.0" layoutY="25.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Gestión de Renovaciones" />

        <!-- Descripción -->
        <Label layoutX="30.0" layoutY="65.0" style="-fx-font-size: 14px;" text="Consulta, busca y gestiona las renovaciones registradas." />

        <!-- Buscador -->
        <TextField fx:id="txtBuscar" layoutX="30.0" layoutY="110.0" prefHeight="40.0" prefWidth="370.0" promptText="Buscar por usuario, fecha o observación..." />

        <!-- Botón Ver Ficha -->
        <Button fx:id="btnVerFicha" layoutX="415.0" layoutY="110.0" mnemonicParsing="false" onAction="#verFicha" prefHeight="40.0" prefWidth="170.0" text="Ver Ficha" />

        <!-- Botones CRUD -->
        <Button fx:id="btnAgregar" layoutX="30.0" layoutY="172.0" mnemonicParsing="false" onAction="#agregarRenovacion" prefHeight="40.0" prefWidth="170.0" text="Añadir Renovación" />

        <Button fx:id="btnEditar" layoutX="227.0" layoutY="172.0" mnemonicParsing="false" onAction="#editarRenovacion" prefHeight="40.0" prefWidth="170.0" text="Editar Renovación" />

        <Button fx:id="btnEliminar" layoutX="415.0" layoutY="172.0" mnemonicParsing="false" onAction="#eliminarRenovacion" prefHeight="40.0" prefWidth="170.0" text="Borrar Renovación" />

        <!-- Tabla -->
        <TableView fx:id="tblRenovaciones" layoutX="30.0" layoutY="230.0" prefHeight="630.0" prefWidth="1004.0">

            <columns>

                <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />

                <TableColumn fx:id="colUsuario" prefWidth="241.0" text="Usuario" />

                <TableColumn fx:id="colFechaRenovacion" prefWidth="218.0" text="Fecha Renovación" />

                <TableColumn fx:id="colFechaSiguiente" prefWidth="246.0" text="Fecha Siguiente" />

                <TableColumn fx:id="colObservaciones" prefWidth="225.0" text="Observaciones" />

            </columns>

        </TableView>

    </children>

</AnchorPane>