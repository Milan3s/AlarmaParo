<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="470.0" prefWidth="700.0" styleClass="mainFxmlClass" stylesheets="@../styles/formborraralarma.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.FormRenovacionBorrarAlarmaController">

    <children>

        <!-- Título -->
        <Label layoutX="30.0" layoutY="25.0" styleClass="tituloPrincipal" text="Borrar Alarma" />

        <!-- Descripción -->
        <Label layoutX="30.0" layoutY="65.0" styleClass="subtituloPrincipal" text="Elimina la renovación y su recordatorio asociado." />

        <!-- Usuario -->
        <Label layoutX="30.0" layoutY="110.0" styleClass="etiquetaCampo" text="Usuario" />

        <ComboBox fx:id="cmbUsuario" layoutX="30.0" layoutY="135.0" prefHeight="40.0" prefWidth="620.0" promptText="Seleccione un usuario..." styleClass="comboFormulario" />

        <!-- Fecha Renovación -->
        <Label layoutX="30.0" layoutY="195.0" styleClass="etiquetaCampo" text="Fecha Renovación" />

        <DatePicker fx:id="dpFechaRenovacion" layoutX="30.0" layoutY="220.0" prefHeight="40.0" prefWidth="180.0" styleClass="datePickerFormulario" />

        <!-- Próxima Renovación -->
        <Label layoutX="250.0" layoutY="195.0" styleClass="etiquetaCampo" text="Próxima Renovación" />

        <DatePicker fx:id="dpFechaSiguiente" layoutX="250.0" layoutY="220.0" prefHeight="40.0" prefWidth="180.0" styleClass="datePickerFormulario" />

        <!-- Días Antes -->
        <Label layoutX="470.0" layoutY="195.0" styleClass="etiquetaCampo" text="Días Antes" />

        <Spinner fx:id="spDiasAntes" editable="true" layoutX="470.0" layoutY="220.0" prefHeight="40.0" prefWidth="180.0" styleClass="spinnerFormulario" />

        <!-- Observaciones -->
        <Label layoutX="30.0" layoutY="280.0" styleClass="etiquetaCampo" text="Observaciones" />

        <TextArea fx:id="txtObservaciones" layoutX="30.0" layoutY="305.0" prefHeight="80.0" prefWidth="620.0" promptText="Introduce las observaciones..." styleClass="textAreaFormulario" wrapText="true" />

        <!-- Botones -->
        <Button fx:id="btnBorrar" layoutX="200.0" layoutY="415.0" mnemonicParsing="false" onAction="#borrar" prefHeight="40.0" prefWidth="120.0" styleClass="botonPeligro" text="Borrar" />

        <Button fx:id="btnCancelar" layoutX="380.0" layoutY="415.0" mnemonicParsing="false" onAction="#cancelar" prefHeight="40.0" prefWidth="120.0" styleClass="botonCancelar" text="Cancelar" />

    </children>

</AnchorPane>