<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="470.0" prefWidth="700.0" styleClass="mainFxmlClass" stylesheets="@../styles/formagregaralarma.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="main.FormRenovacionAgregarAlarmaController">

    <children>

        <!-- Título -->
        <Label layoutX="30.0" layoutY="25.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Agregar Alarma" />

        <!-- Descripción -->
        <Label layoutX="30.0" layoutY="65.0" style="-fx-font-size: 14px;" text="Registra un nuevo recordatorio para una renovación." />

        <!-- Usuario -->
        <Label layoutX="30.0" layoutY="110.0" text="Usuario" />

        <ComboBox fx:id="cmbUsuario" layoutX="30.0" layoutY="135.0" prefHeight="40.0" prefWidth="620.0" promptText="Seleccione un usuario..." />

        <!-- Fecha Aviso -->
        <Label layoutX="30.0" layoutY="195.0" text="Fecha Aviso" />

        <DatePicker fx:id="dpFechaAviso" layoutX="30.0" layoutY="220.0" prefHeight="40.0" prefWidth="180.0" />

        <!-- Fecha Renovación -->
        <Label layoutX="250.0" layoutY="195.0" text="Fecha Renovación" />

        <DatePicker fx:id="dpFechaRenovacion" layoutX="250.0" layoutY="220.0" prefHeight="40.0" prefWidth="180.0" />

        <!-- Días Antes -->
        <Label layoutX="470.0" layoutY="195.0" text="Días Antes" />

        <Spinner fx:id="spDiasAntes" editable="true" layoutX="470.0" layoutY="220.0" prefHeight="40.0" prefWidth="180.0" />

        <!-- Observaciones -->
        <Label layoutX="30.0" layoutY="280.0" text="Observaciones" />

        <TextArea fx:id="txtObservaciones" layoutX="30.0" layoutY="305.0" prefHeight="80.0" prefWidth="620.0" promptText="Introduce las observaciones..." wrapText="true" />

        <!-- Botones -->
        <Button fx:id="btnGuardar" layoutX="160.0" layoutY="415.0" mnemonicParsing="false" onAction="#guardar" prefHeight="40.0" prefWidth="120.0" text="Guardar" />

        <Button fx:id="btnLimpiar" layoutX="290.0" layoutY="415.0" mnemonicParsing="false" onAction="#limpiar" prefHeight="40.0" prefWidth="120.0" text="Limpiar" />

        <Button fx:id="btnCancelar" layoutX="420.0" layoutY="415.0" mnemonicParsing="false" onAction="#cancelar" prefHeight="40.0" prefWidth="120.0" text="Cancelar" />

    </children>

</AnchorPane>